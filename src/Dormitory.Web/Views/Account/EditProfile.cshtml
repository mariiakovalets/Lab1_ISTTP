@model Dormitory.Domain.Entities.Student

@{
    ViewData["Title"] = "Редагувати профіль";
}

<h2>Редагувати профіль</h2>
<hr />

@if (TempData["Error"] != null)
{
    <div class="alert alert-warning">@TempData["Error"]</div>
}

<div class="row">
    <div class="col-md-6">
        <div class="card">
            <div class="card-body">
                <h5 class="card-title mb-3">Редагування даних</h5>

                <form asp-action="EditProfile" method="post">

                    <div class="form-group mb-3">
                        <label class="control-label">ПІБ</label>
                        <input name="fullname" class="form-control" value="@Model.Fullname" />
                    </div>

                    <div class="form-group mb-3">
                        <label class="control-label">Курс (1–6)</label>
                        <input name="course" type="number" min="1" max="6" class="form-control" value="@Model.Course" />
                    </div>

                    <div class="form-group mb-3">
                        <label class="control-label">Факультет</label>
                        <select name="facultyid" class="form-select" asp-items="@(ViewData["FacultyId"] as SelectList)">
                        </select>
                    </div>

                    <div class="form-group mb-3">
                        <label class="control-label">Стать</label>
                        <select name="gender" class="form-select">
                            <option value="Ч" selected="@(Model.Gender == "Ч")">Чоловіча</option>
                            <option value="Ж" selected="@(Model.Gender == "Ж")">Жіноча</option>
                        </select>
                    </div>

                    <div class="form-group mb-3">
                        <label class="control-label">Дата народження</label>
                        <input name="birthdate" type="date" class="form-control"
                               value="@Model.Birthdate?.ToString("yyyy-MM-dd")" />
                    </div>

                    <hr />

                    <div class="form-group mb-3">
                        <label class="control-label">Місце проживання</label>
                        <input name="address" class="form-control" value="@Model.Address" />
                    </div>

                    <div class="form-group mb-3">
                        <label class="control-label">Телефон</label>
                        <input name="phone" class="form-control" value="@Model.Phone" placeholder="0XXXXXXXXX або +380XXXXXXXXX" />
                    </div>

                    <div class="form-group mb-3">
                        <label class="control-label">Email</label>
                        <input name="email" type="email" class="form-control" value="@Model.Email" />
                    </div>

                    <div class="d-flex gap-2 mt-3">
                        <button type="submit" class="btn btn-outline-primary rounded-pill">Зберегти</button>
                        <a asp-action="Profile" class="btn btn-outline-secondary rounded-pill">Скасувати</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
