@{
    ViewData["Title"] = "Мій профіль";
    var user = ViewBag.User as Dormitory.Domain.Entities.User;
    var student = ViewBag.Student as Dormitory.Domain.Entities.Student;
}

<h2>Профіль</h2>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success">@TempData["Success"]</div>
}
@if (TempData["Error"] != null)
{
    <div class="alert alert-warning">@TempData["Error"]</div>
}

@if (ViewBag.MissingDocs != null)
{
    var missing = ViewBag.MissingDocs as List<string>;
    <div class="alert alert-warning mt-3">
        <strong>Увага!</strong> Відсутні обов'язкові документи: @string.Join(", ", missing).
        Без них ви не зможете подати нову заяву. <a asp-action="MyDocuments">Завантажити</a>
    </div>
}

<div class="row mt-4">
    <div class="col-md-8">
        @if (student != null)
        {
            <div class="card">
                <div class="card-body">
                    <table class="table table-borderless">
                        <tr>
                            <td class="text-muted" style="width:200px;">ПІБ</td>
                            <td><strong>@student.Fullname</strong></td>
                        </tr>
                        <tr>
                            <td class="text-muted">Email</td>
                            <td>@student.Email</td>
                        </tr>
                        <tr>
                            <td class="text-muted">Телефон</td>
                            <td>@student.Phone</td>
                        </tr>
                        <tr>
                            <td class="text-muted">Курс</td>
                            <td>@student.Course</td>
                        </tr>
                        <tr>
                            <td class="text-muted">Факультет</td>
                            <td>@student.Faculty?.Facultyname</td>
                        </tr>
                        <tr>
                            <td class="text-muted">Дата народження</td>
                            <td>@student.Birthdate?.ToString("dd.MM.yyyy")</td>
                        </tr>
                        <tr>
                            <td class="text-muted">Стать</td>
                            <td>@(student.Gender == "Ч" ? "Чоловіча" : student.Gender == "Ж" ? "Жіноча" : student.Gender)</td>
                        </tr>
                        <tr>
                            <td class="text-muted">Адреса</td>
                            <td>@student.Address</td>
                        </tr>
                        <tr>
                            <td class="text-muted">Відстань до Києва</td>
                            <td>@student.DistanceKm км</td>
                        </tr>
                        <tr>
                            <td class="text-muted">Пільга</td>
                            <td>@(student.HasPrivilege ? "Так" : "Ні")</td>
                        </tr>
                        @if (ViewBag.CurrentRoom != null)
                        {
                            var room = ViewBag.CurrentRoom as Dormitory.Domain.Entities.Room;
                            <tr>
                                <td class="text-muted">Кімната</td>
                                <td><strong>@room?.Roomnumber</strong> (поверх @room?.Floor)</td>
                            </tr>
                        }
                        else
                        {
                            <tr>
                                <td class="text-muted">Кімната</td>
                                <td class="text-muted">Не заселений</td>
                            </tr>
                        }
                    </table>
                    <div class="d-flex gap-2">
                        <a asp-action="EditProfile" class="btn btn-outline-primary rounded-pill">Редагувати профіль</a>
        <a asp-action="ChangePassword" class="btn btn-outline-primary rounded-pill">Змінити пароль</a>
                        <a asp-action="MyDocuments" class="btn btn-outline-secondary rounded-pill">Документи</a>
                    </div>
                </div>
            </div>
        }
        else
        {
            <div class="alert alert-info mt-3">
                Ваш акаунт ще не прив'язаний до студента в базі даних. Зверніться до адміністратора.
            </div>
        }
    </div>
</div>

<a asp-controller="Home" asp-action="Index" class="btn btn-outline-secondary rounded-pill mt-3">На головну</a>
