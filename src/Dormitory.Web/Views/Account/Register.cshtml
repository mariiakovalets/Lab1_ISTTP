@model Dormitory.Web.Models.RegisterViewModel

@{
    ViewData["Title"] = "Реєстрація";
}

<h2>Реєстрація в системі гуртожитку</h2>
<hr />

<div class="row">
    <div class="col-md-6">
        <form asp-action="Register">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>

            <h5 class="mt-3 mb-3">Дані для входу</h5>

            <div class="form-group mb-3">
                <label asp-for="Email" class="control-label"></label>
                <input asp-for="Email" class="form-control" />
                <span asp-validation-for="Email" class="text-danger"></span>
            </div>
            <div class="form-group mb-3">
                <label asp-for="Password" class="control-label"></label>
                <input asp-for="Password" class="form-control" type="password" />
                <span asp-validation-for="Password" class="text-danger"></span>
            </div>
            <div class="form-group mb-3">
                <label asp-for="PasswordConfirm" class="control-label"></label>
                <input asp-for="PasswordConfirm" class="form-control" type="password" />
                <span asp-validation-for="PasswordConfirm" class="text-danger"></span>
            </div>

            <hr />
            <h5 class="mt-3 mb-3">Персональні дані</h5>

            <div class="form-group mb-3">
                <label asp-for="FullName" class="control-label"></label>
                <input asp-for="FullName" class="form-control" placeholder="Прізвище Ім'я По-батькові" />
                <span asp-validation-for="FullName" class="text-danger"></span>
            </div>
            <div class="row">
                <div class="col-md-6">
                    <div class="form-group mb-3">
                        <label asp-for="Course" class="control-label"></label>
                        <select asp-for="Course" class="form-control">
                            <option value="">Оберіть курс</option>
                            <option value="1">1 курс</option>
                            <option value="2">2 курс</option>
                            <option value="3">3 курс</option>
                            <option value="4">4 курс</option>
                            <option value="5">5 курс</option>
                            <option value="6">6 курс</option>
                        </select>
                        <span asp-validation-for="Course" class="text-danger"></span>
                    </div>
                </div>
                <div class="col-md-6">
                    <div class="form-group mb-3">
                        <label asp-for="Gender" class="control-label"></label>
                        <select asp-for="Gender" class="form-control">
                            <option value="">Оберіть стать</option>
                            <option value="Ч">Чоловіча</option>
                            <option value="Ж">Жіноча</option>
                        </select>
                        <span asp-validation-for="Gender" class="text-danger"></span>
                    </div>
                </div>
            </div>
            <div class="form-group mb-3">
                <label asp-for="Birthdate" class="control-label"></label>
                <input asp-for="Birthdate" class="form-control" type="date" />
                <span asp-validation-for="Birthdate" class="text-danger"></span>
            </div>
            <div class="form-group mb-3">
                <label asp-for="FacultyId" class="control-label"></label>
                <select asp-for="FacultyId" class="form-control" asp-items="@(ViewData["FacultyId"] as SelectList)">
                    <option value="">Оберіть факультет</option>
                </select>
                <span asp-validation-for="FacultyId" class="text-danger"></span>
            </div>
            <div class="form-group mb-3">
                <label asp-for="Address" class="control-label"></label>
                <input asp-for="Address" class="form-control" placeholder="напр. м. Дніпро" />
                <span asp-validation-for="Address" class="text-danger"></span>
            </div>
            <div class="row">
                <div class="col-md-6">
                    <div class="form-group mb-3">
                        <label asp-for="Phone" class="control-label"></label>
                        <input asp-for="Phone" class="form-control" placeholder="0XXXXXXXXX" />
                        <span asp-validation-for="Phone" class="text-danger"></span>
                    </div>
                </div>
                <div class="col-md-6">
                    <div class="form-group mb-3">
                        <label asp-for="DistanceKm" class="control-label"></label>
                        <input asp-for="DistanceKm" class="form-control" placeholder="напр. 490" />
                        <span asp-validation-for="DistanceKm" class="text-danger"></span>
                    </div>
                </div>
            </div>
            <div class="form-check mb-3">
                <input asp-for="HasPrivilege" class="form-check-input" />
                <label asp-for="HasPrivilege" class="form-check-label"></label>
            </div>

            <div class="d-flex gap-2 mt-3">
                <input type="submit" value="Зареєструватись" class="btn btn-outline-primary rounded-pill" />
                <a asp-action="Login" class="btn btn-outline-secondary rounded-pill">Вже є акаунт?</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
