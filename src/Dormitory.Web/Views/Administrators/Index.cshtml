@model IEnumerable<Dormitory.Domain.Entities.Administrator>

@{
    ViewData["Title"] = "Адміністратори";
}

<h1>Список адміністраторів</h1>

<p>
    <a asp-action="Create">Додати нового адміністратора</a>
</p>
<table class="table">
    <thead>
        <tr>
            <th>
                @Html.DisplayNameFor(model => model.Username)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Fullname)
            </th>
            <th></th>
        </tr>
    </thead>
    <tbody>
@foreach (var item in Model) {
        <tr>
            <td>
                @Html.DisplayFor(modelItem => item.Username)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.Fullname)
            </td>
            <td>
                <a asp-action="Edit" asp-route-id="@item.Adminid">Редагувати</a> |
                <a asp-action="Details" asp-route-id="@item.Adminid">Деталі</a> |
                <a asp-action="Delete" asp-route-id="@item.Adminid">Видалити</a>
            </td>
        </tr>
}
    </tbody>
</table>
