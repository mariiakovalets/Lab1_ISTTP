@model IEnumerable<Dormitory.Domain.Entities.Application>

@{
    ViewData["Title"] = "Заяви";
}

<h1>Список заяв</h1>

<p>
    <a asp-action="Import" class="btn btn-outline-primary mb-3 rounded-pill">Завантажити з файлу</a>
    <a asp-action="Export" class="btn btn-outline-primary mb-3 rounded-pill">Експортувати у файл</a>
</p>

<table class="table">
    <thead>
        <tr>
            <th>Студент</th>
            <th>Тип</th>
            <th>Період</th>
            <th>Дата подачі</th>
            <th>Статус</th>
            <th>Дата рішення</th>
            <th></th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            var statusName = item.Status?.Statusname ?? "";
            <tr>
                <td>@item.Student?.Fullname</td>
                <td>@item.Applicationtype</td>
                <td>@item.Academicperiod</td>
                <td>@item.Submissiondate?.ToString("dd.MM.yyyy HH:mm")</td>
                <td>@statusName</td>
                <td>@item.Decisiondate?.ToString("dd.MM.yyyy")</td>
                <td>
                    <div class="d-flex gap-1">
                        @if (statusName == "На розгляді")
                        {
                            <a asp-action="Review" asp-route-id="@item.Applicationid" class="btn btn-sm btn-outline-primary rounded-pill">Розглянути</a>
                        }
                        <a asp-action="Details" asp-route-id="@item.Applicationid" class="btn btn-sm btn-outline-secondary rounded-pill">Деталі</a>
                    </div>
                </td>
            </tr>
        }
    </tbody>
</table>
