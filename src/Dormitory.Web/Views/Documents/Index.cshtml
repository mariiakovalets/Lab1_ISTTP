@model IEnumerable<Dormitory.Domain.Entities.Document>

@{
    ViewData["Title"] = "Документи";
    var grouped = Model.GroupBy(d => d.Student?.Fullname ?? "Невідомий").OrderBy(g => g.Key);
}

<h1>Документи студентів</h1>

@foreach (var group in grouped)
{
    <div class="card mt-3">
        <div class="card-body">
            <h5 class="card-title">@group.Key</h5>
            <table class="table table-sm mb-0">
                <thead>
                    <tr>
                        <th>Тип документа</th>
                        <th>Дата видачі</th>
                        <th>Дата закінчення дії</th>
                        <th>Дата завантаження</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in group.OrderBy(d => d.Type?.Typename))
                    {
                        var isExpired = item.Expirydate.HasValue && item.Expirydate.Value < DateTime.Today;
                        <tr>
                            <td>
                                @item.Type?.Typename
                                @if (isExpired)
                                {
                                    <span class="badge bg-danger ms-1">Прострочений</span>
                                }
                            </td>
                            <td>@item.Issuedate?.ToString("dd.MM.yyyy")</td>
                            <td>@item.Expirydate?.ToString("dd.MM.yyyy")</td>
                            <td>@item.Uploaddate?.ToString("dd.MM.yyyy")</td>
                            <td>
                                @if (item.Filecontent != null && item.Filecontent.Length > 0)
                                {
                                    <a asp-action="Download" asp-route-id="@item.Documentid" class="btn btn-sm btn-outline-secondary rounded-pill">Завантажити</a>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
}

@if (!grouped.Any())
{
    <p class="text-muted mt-3">Документів ще немає.</p>
}
