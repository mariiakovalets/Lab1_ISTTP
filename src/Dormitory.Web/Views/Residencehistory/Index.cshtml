@model IEnumerable<Dormitory.Domain.Entities.Residencehistory>

@{
    ViewData["Title"] = "Історія проживання";
}

<h1>Історія проживання</h1>

<table class="table mt-3">
    <thead>
        <tr>
            <th>Студент</th>
            <th>Кімната</th>
            <th>Поверх</th>
            <th>Дата заселення</th>
            <th>Дата виселення</th>
            <th>Статус</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            var isActive = !item.Checkoutdate.HasValue;
            <tr>
                <td>@item.Student?.Fullname</td>
                <td>@item.Room?.Roomnumber</td>
                <td>@item.Room?.Floor</td>
                <td>@item.Checkindate?.ToString("dd.MM.yyyy")</td>
                <td>@item.Checkoutdate?.ToString("dd.MM.yyyy")</td>
                <td>@(isActive ? "Проживає" : "Виселений")</td>
            </tr>
        }
    </tbody>
</table>

@if (!Model.Any())
{
    <p class="text-muted mt-3">Записів немає.</p>
}
