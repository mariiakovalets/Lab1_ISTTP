@model IEnumerable<Dormitory.Domain.Entities.Student>

@{
    ViewData["Title"] = "Студенти";
}

<h1>Список студентів</h1>

<p>
    <a asp-action="Create">Додати нового студента</a>
</p>
<table class="table">
    <thead>
        <tr>
            <th>
                @Html.DisplayNameFor(model => model.Fullname)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Course)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Birthdate)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Address)
            </th>
            <th>@Html.DisplayNameFor(model => model.DistanceKm)</th>
            <th>
                @Html.DisplayNameFor(model => model.Phone)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Email)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Gender)
            </th>
            <th>
                Факультет
            </th>
            <th></th>
        </tr>
    </thead>
    <tbody>
@foreach (var item in Model) {
        <tr>
            <td>
                @Html.DisplayFor(modelItem => item.Fullname)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.Course)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.Birthdate)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.Address)
            </td>
            <td>@Html.DisplayFor(modelItem => item.DistanceKm)</td>
            <td>
                @Html.DisplayFor(modelItem => item.Phone)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.Email)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.Gender)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.Faculty.Facultyname)
            </td>
            <td>
                <a asp-action="Edit" asp-route-id="@item.Studentid">Редагувати</a> |
                <a asp-action="Details" asp-route-id="@item.Studentid">Деталі</a> |
                <a asp-action="Delete" asp-route-id="@item.Studentid">Видалити</a>
            </td>
        </tr>
}
    </tbody>
</table>