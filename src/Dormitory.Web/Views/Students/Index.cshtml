@model IEnumerable<Dormitory.Domain.Entities.Student>

@{
    ViewData["Title"] = "Студенти";
}

<h1>Список студентів</h1>

<p>
<a asp-action="Create" class="btn btn-outline-primary mb-3 rounded-pill">Додати нового студента</a>
<a asp-action="Import" class="btn btn-outline-primary mb-3 ms-2 rounded-pill">Завантажити з файлу</a>
<a asp-action="Export" class="btn btn-outline-primary mb-3 ms-2 rounded-pill">Експортувати у файл</a>
</p>
<table class="table">
    <thead>
        <tr>
            <th>
                @Html.DisplayNameFor(model => model.Fullname)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Course)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Birthdate)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Address)
            </th>
            <th>@Html.DisplayNameFor(model => model.DistanceKm)</th>
            <th>
                @Html.DisplayNameFor(model => model.Phone)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Email)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Gender)
            </th>
            <th>
                Факультет
            </th>
            <th></th>
        </tr>
    </thead>
    <tbody>
@foreach (var item in Model) {
        <tr>
            <td>
                @Html.DisplayFor(modelItem => item.Fullname)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.Course)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.Birthdate)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.Address)
            </td>
            <td>@Html.DisplayFor(modelItem => item.DistanceKm)</td>
            <td>
                @Html.DisplayFor(modelItem => item.Phone)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.Email)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.Gender)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.Faculty.Facultyname)
            </td>
<td>
    <div class="d-flex gap-1">
        <a asp-action="Edit" asp-route-id="@item.Studentid" class="btn btn-sm btn-outline-primary rounded-pill">Редагувати</a>
        <a asp-action="Details" asp-route-id="@item.Studentid" class="btn btn-sm btn-outline-primary rounded-pill">Деталі</a>
        <a asp-action="Delete" asp-route-id="@item.Studentid" class="btn btn-sm btn-outline-danger rounded-pill">Видалити</a>
    </div>
</td>
        </tr>
}
    </tbody>
</table>